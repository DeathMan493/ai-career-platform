APP_NAME=AI Platform API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=ai-platform
MONGODB_DATABASE=ai_platform
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
SECRET_KEY=change-this-before-production
OPENALEX_API_KEY=replace-with-your-openalex-key
OPENALEX_BASE_URL=https://api.openalex.org
USAJOBS_API_KEY=replace-with-your-usajobs-key
USAJOBS_USER_AGENT=your-email@example.com
USAJOBS_HOST=data.usajobs.gov
ONET_API_KEY=replace-with-your-onet-api-key
ONET_BASE_URL=https://services.onetcenter.org/ws/
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=backend/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=
DATA_DIR=data
